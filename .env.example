# DPR Analyzer Pro — environment variables.
# Copy this file to .env (local dev) and configure the same keys in Netlify
# for production. NEVER commit a real .env file.

# ===========================================================================
# REQUIRED
# ===========================================================================

# ---- Client-safe (exposed to the browser, must be prefixed VITE_) ----
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_URL=http://localhost:5173

# ---- Server-only (Netlify Functions; NEVER in the React bundle) ----
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================================================
# RESEND (recommended — functions silently no-op without these)
# ===========================================================================

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@dpranalyzer.com
OPERATOR_EMAIL=

# ===========================================================================
# OPTIONAL
# ===========================================================================

# Make.com webhook fired alongside confirm-upload; receives the full
# submission payload (jobId, files, client metadata, admin URL).
MAKE_WEBHOOK_URL=

# Cron tunables — all have safe defaults if unset.
# RETENTION_DAYS=30              # file purge window for closed jobs
# ORPHAN_AGE_HOURS=24            # unconfirmed-submission cutoff
# CREDIT_EXPIRY_MONTHS=12        # FIFO credit lifetime
# LOW_BALANCE_THRESHOLD=3        # at-or-below triggers reminder email
